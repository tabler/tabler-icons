{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "rootDir": "./src",
    "outDir": "./dist/esm"
  },
  "include": ["src"],
  "exclude": ["**/node_modules", "**/*.test.*", "**/*.spec.*"]
}
