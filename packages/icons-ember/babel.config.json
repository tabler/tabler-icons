{
  "plugins": [
    [
      "@babel/plugin-transform-typescript",
      {
        "allExtensions": true,
        "onlyRemoveTypeImports": true,
        "allowDeclareFields": true
      }
    ],
    [
      "babel-plugin-ember-template-compilation",
      {
        "targetFormat": "hbs",
        "transforms": []
      }
    ]
  ]
}

