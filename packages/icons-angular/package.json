{
  "name": "@tabler/icons-angular",
  "version": "3.45.0",
  "license": "MIT",
  "description": "A set of free MIT-licensed high-quality SVG icons for you to use in your Angular projects.",
  "homepage": "https://tabler.io/icons",
  "bugs": {
    "url": "https://github.com/tabler/tabler-icons/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/codecalm"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tabler/tabler-icons.git",
    "directory": "packages/icons-angular"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "angular",
    "icons",
    "svg",
    "tabler",
    "ui",
    "icon-pack"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "pnpm run clean && pnpm run copy:license && pnpm run build:icons && pnpm run typecheck && pnpm run build:ng",
    "build:icons": "node build.mjs",
    "build:ng": "ng build --configuration=production",
    "copy:license": "cp ../../LICENSE ./LICENSE",
    "clean": "rm -rf dist && find src/icons -mindepth 1 ! -name '.gitkeep' -delete",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit --inlineSources false",
    "test": "ng test --no-watch --no-progress",
    "test:watch": "ng test"
  },
  "main": "./dist/fesm2022/tabler-icons-angular.mjs",
  "module": "./dist/fesm2022/tabler-icons-angular.mjs",
  "types": "./dist/types/tabler-icons-angular.d.ts",
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular-devkit/build-angular": "^22.0.7",
    "@angular/animations": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/platform-browser": "^22.0.7",
    "@angular/platform-browser-dynamic": "^22.0.7",
    "@types/jasmine": "~6.0.0",
    "jasmine-core": "~6.3.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "ng-packagr": "^22.0.1",
    "tslib": "^2.8.1",
    "typescript": "catalog:",
    "zone.js": "~0.16.2"
  },
  "peerDependencies": {
    "@angular/common": ">=21.0.0",
    "@angular/core": ">=21.0.0",
    "@tabler/icons": "workspace:*"
  }
}
